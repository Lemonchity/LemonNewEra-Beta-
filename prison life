local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ESP_Enabled = false
local ESP_Cache = {}

-- Функция очистки

local function ClearAllESP()
    for _, data in pairs(ESP_Cache) do
        if data.Conn then data.Conn:Disconnect() end
        if data.Gui then data.Gui:Destroy() end
    end
    table.clear(ESP_Cache)
end

-- Функция отрисовки

local function CreateESP(player)
    if player == LocalPlayer then return end

    local conn = RunService.RenderStepped:Connect(function()
        if not ESP_Enabled then return end
        
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        -- Если персонаж умер или исчез, убираем GUI
        if not head or not hum or not hrp or hum.Health <= 0 then 
            if ESP_Cache[player] and ESP_Cache[player].Gui then
                ESP_Cache[player].Gui:Destroy()
                ESP_Cache[player].Gui = nil
            end
            return 
        end

        -- Создание GUI (BillboardGui)
        if not ESP_Cache[player] or not ESP_Cache[player].Gui then
            local bgui = Instance.new("BillboardGui")
            bgui.Name = "ESP_UI"
            bgui.Size = UDim2.new(4, 0, 1.5, 0)
            bgui.AlwaysOnTop = true
            bgui.MaxDistance = 1000 -- Дистанция отрисовки
            bgui.Parent = head
            
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 0.5, 0)
            label.BackgroundTransparency = 1
            label.TextStrokeTransparency = 0
            label.Font = Enum.Font.SourceSansBold
            label.TextSize = 14
            label.Parent = bgui

            local healthBar = Instance.new("Frame")
            healthBar.Size = UDim2.new(1, 0, 0.1, 0)
            healthBar.Position = UDim2.new(0, 0, 0.6, 0)
            healthBar.BackgroundColor3 = Color3.new(0, 0, 0)
            healthBar.BorderSizePixel = 1
            healthBar.Parent = bgui

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new(1, 0, 1, 0)
            fill.BorderSizePixel = 0
            fill.Parent = healthBar

            ESP_Cache[player] = {Gui = bgui, Conn = conn, Label = label, Fill = fill}
        end

        -- ЦВЕТОВАЯ СХЕМА ПО КОМАНДАМ
        local color = Color3.new(1, 1, 1) -- Белый (если нет команды)
        local teamName = player.Team and player.Team.Name or ""

        if teamName == "Criminals" then
            color = Color3.fromRGB(255, 0, 0)    -- КРАСНЫЙ
        elseif teamName == "Inmates" then
            color = Color3.fromRGB(255, 255, 0)  -- ЖЕЛТЫЙ
        elseif teamName == "Guards" then
            color = Color3.fromRGB(0, 170, 255)  -- СИНИЙ
        end

        -- Обновление данных
        local data = ESP_Cache[player]
        if data then
            data.Label.Text = player.Name .. " [" .. teamName .. "]"
            data.Label.TextColor3 = color
            data.Fill.BackgroundColor3 = color
            -- Масштабирование полоски HP
            data.Fill.Size = UDim2.new(math.clamp(hum.Health / hum.MaxHealth, 0, 1), 0, 1, 0)
        end
    end)

    ESP_Cache[player] = {Conn = conn}
end

-- Инициализация

local function Init()
    for _, p in pairs(Players:GetPlayers()) do
        task.spawn(function() CreateESP(p) end)
    end
    Players.PlayerAdded:Connect(function(p)
        task.spawn(function() CreateESP(p) end)
    end)
end

